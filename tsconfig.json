{
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "allowSyntheticDefaultImports": true,
    "allowImportingTsExtensions": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@types/*": [
        "./types/*"
      ],
      "@emotionscare/contracts": [
        "./packages/contracts/index.ts"
      ],
      "@emotionscare/contracts/*": [
        "./packages/contracts/*"
      ],
      "cross-fetch": [
        "./tests/polyfills/cross-fetch.ts"
      ],
      "@playwright/test": [
        "./types/playwright-stub.d.ts"
      ],
      "@axe-core/playwright": [
        "./types/playwright-stub.d.ts"
      ]
    },
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2020",
    "noEmit": true,
    "types": [
      "vite/client",
      "node",
      "vitest/globals"
    ],
    "useDefineForClassFields": true
  },
  "exclude": [
    "node_modules",
    "dist",
    "src/e2e",
    "src/**/*.e2e.test.ts",
    "src/**/*.e2e.test.tsx",
    "tests/e2e",
    "supabase",
    "src/hooks/**/*",
    "src/lib/**/*",
    "src/services/**/*",
    "src/components/**/*",
    "src/contexts/**/*",
    "src/features/**/*",
    "src/core/**/*",
    "src/store/**/*",
    "src/layouts/**/*",
    "src/i18n/**/*",
    "scripts/**/*",
    "services/**/*"
  ],
  "include": [
    "./src",
    "./types",
    "./tests",
    "./test",
    "./services",
    "./scripts",
    "./ci",
    "./tools",
    "./vitest.config.ts",
    "./vitest.*.config.ts"
  ]
}